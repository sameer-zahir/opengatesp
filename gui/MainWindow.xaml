<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenGateSP" Height="780" Width="1180" MinWidth="940" MinHeight="600"
        WindowStartupLocation="CenterScreen" UseLayoutRounding="True" SnapsToDevicePixels="True"
        Background="{DynamicResource Bg}"
        TextElement.Foreground="{DynamicResource Fg}"
        TextElement.FontFamily="Segoe UI" TextElement.FontSize="14">

    <Grid>
    <DockPanel>
        <!-- App bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource BgElev}" Padding="20,12"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="24" Height="24" CornerRadius="6" Background="{DynamicResource Accent}" Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock Text="O" Foreground="{DynamicResource AccentFg}" FontFamily="Consolas" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="OpenGateSP" FontFamily="Consolas" FontSize="19" FontWeight="Bold"
                               Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                    <Border Width="1" Height="18" Background="{DynamicResource BorderStrong}" Margin="14,0"/>
                    <TextBlock x:Name="Breadcrumb" Text="Migration  ›  Home" Style="{DynamicResource Breadcrumb}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="ConnPill" Background="{DynamicResource BgElev2}" CornerRadius="20" Padding="11,5" Margin="0,0,10,0"
                            Cursor="Hand" ToolTip="Connection &amp; settings">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="ConnDot" Width="9" Height="9" Fill="{DynamicResource Warn}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ConnStatus" Text="Not connected" Style="{DynamicResource Muted}"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="BtnSettings" Style="{DynamicResource ThemeToggle}" ToolTip="Settings"
                            FontFamily="Segoe MDL2 Assets" Content="&#xE713;"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource BgElev}" Padding="20,8"
                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0">
            <DockPanel>
                <ProgressBar x:Name="BusyBar" DockPanel.Dock="Right" Width="130" Height="3"
                             IsIndeterminate="True" Visibility="Collapsed"
                             Background="Transparent" Foreground="{DynamicResource Accent}" BorderThickness="0"/>
                <TextBlock x:Name="StatusText" Text="Ready." Style="{DynamicResource Muted}"/>
            </DockPanel>
        </Border>

        <!-- Body: nav rail + content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Nav rail -->
            <Border Grid.Column="0" Background="{DynamicResource BgElev}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
                <DockPanel Margin="12,16">
                    <StackPanel DockPanel.Dock="Bottom">
                        <RadioButton x:Name="NavConnect" GroupName="Nav" Style="{DynamicResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{DynamicResource NavIcon}" Text="&#xE774;"/><TextBlock Text="Connect" VerticalAlignment="Center"/></StackPanel>
                        </RadioButton>
                        <TextBlock Text="PowerShell · MCP · GUI" FontFamily="Consolas" FontSize="11"
                                   Foreground="{DynamicResource FgMute}" Margin="14,12,0,2"/>
                    </StackPanel>
                    <StackPanel>
                        <RadioButton x:Name="NavHome" GroupName="Nav" Style="{DynamicResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{DynamicResource NavIcon}" Text="&#xE80F;"/><TextBlock Text="Home" VerticalAlignment="Center"/></StackPanel>
                        </RadioButton>
                        <TextBlock Text="MIGRATION" Style="{DynamicResource NavGroupHeader}" Margin="14,14,0,6"/>
                        <RadioButton x:Name="NavExplore" GroupName="Nav" Style="{DynamicResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{DynamicResource NavIcon}" Text="&#xE721;"/><TextBlock Text="Explore" VerticalAlignment="Center"/></StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavCopy" GroupName="Nav" Style="{DynamicResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{DynamicResource NavIcon}" Text="&#xE8C8;"/><TextBlock Text="Copy" VerticalAlignment="Center"/></StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavPreCheck" GroupName="Nav" Style="{DynamicResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{DynamicResource NavIcon}" Text="&#xE73E;"/><TextBlock Text="Pre-check" VerticalAlignment="Center"/></StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavReports" GroupName="Nav" Style="{DynamicResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{DynamicResource NavIcon}" Text="&#xE72E;"/><TextBlock Text="Security" VerticalAlignment="Center"/></StackPanel>
                        </RadioButton>
                        <TextBlock Text="ACTIVITY" Style="{DynamicResource NavGroupHeader}" Margin="14,18,0,6"/>
                        <RadioButton x:Name="NavTasks" GroupName="Nav" Style="{DynamicResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{DynamicResource NavIcon}" Text="&#xE81C;"/><TextBlock Text="Tasks" VerticalAlignment="Center"/></StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavScheduled" GroupName="Nav" Style="{DynamicResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{DynamicResource NavIcon}" Text="&#xE787;"/><TextBlock Text="Scheduled" VerticalAlignment="Center"/></StackPanel>
                        </RadioButton>
                        <TextBlock Text="GOVERNANCE" Style="{DynamicResource NavGroupHeader}" Margin="14,18,0,6"/>
                        <RadioButton x:Name="NavProvision" GroupName="Nav" Style="{DynamicResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Style="{DynamicResource NavIcon}" Text="&#xE710;"/><TextBlock Text="Provisioning" VerticalAlignment="Center"/></StackPanel>
                        </RadioButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content host (fluid-scaled, scrolls if a view overflows) -->
            <Grid Grid.Column="1" Background="{DynamicResource Bg}">
              <ScrollViewer x:Name="ContentScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid x:Name="ContentRoot">
                  <Grid.LayoutTransform><ScaleTransform x:Name="UiScale" ScaleX="1" ScaleY="1"/></Grid.LayoutTransform>

                <!-- HOME -->
                <StackPanel x:Name="ViewHome" Margin="28,26">
                        <TextBlock Text="What do you want to do?" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource Fg}"/>
                        <TextBlock Text="Free and open. Run it from this window, a PowerShell prompt, or an AI assistant over MCP — same engine behind all three."
                                   Style="{DynamicResource Muted}" Margin="0,8,0,0" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left"/>
                        <WrapPanel Margin="0,22,0,0">
                            <Button x:Name="CardMigrate" Style="{DynamicResource Card}" Width="300">
                                <StackPanel>
                                    <TextBlock Text="Migrate a file share" Style="{DynamicResource CardTitle}"/>
                                    <TextBlock Text="Move a folder tree into a SharePoint library, intact." Style="{DynamicResource CardBody}"/>
                                    <TextBlock Text="Files · Folders · Timestamps" Style="{DynamicResource CardMeta}"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CardCopySite" Style="{DynamicResource Card}" Width="300">
                                <StackPanel>
                                    <TextBlock Text="Copy a SharePoint site" Style="{DynamicResource CardTitle}"/>
                                    <TextBlock Text="Copy a site's structure and content to another site in your tenant." Style="{DynamicResource CardBody}"/>
                                    <TextBlock Text="Lists · Libraries · Files · Same tenant" Style="{DynamicResource CardMeta}"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CardPreCheck" Style="{DynamicResource Card}" Width="300">
                                <StackPanel>
                                    <TextBlock Text="Pre-check a source" Style="{DynamicResource CardTitle}"/>
                                    <TextBlock Text="Spot what SharePoint will reject before you copy." Style="{DynamicResource CardBody}"/>
                                    <TextBlock Text="Long paths · Bad names · Big files" Style="{DynamicResource CardMeta}"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CardExplore" Style="{DynamicResource Card}" Width="300">
                                <StackPanel>
                                    <TextBlock Text="Explore a source site" Style="{DynamicResource CardTitle}"/>
                                    <TextBlock Text="Assess a SharePoint site before you migrate — blockers, big files, sharing." Style="{DynamicResource CardBody}"/>
                                    <TextBlock Text="Checked-out · Large files · Sharing · Workflows" Style="{DynamicResource CardMeta}"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CardReports" Style="{DynamicResource Card}" Width="300">
                                <StackPanel>
                                    <TextBlock Text="Report on access" Style="{DynamicResource CardTitle}"/>
                                    <TextBlock Text="See who can reach a site and where sharing leaks." Style="{DynamicResource CardBody}"/>
                                    <TextBlock Text="External · Permissions · Inventory" Style="{DynamicResource CardMeta}"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CardProvision" Style="{DynamicResource Card}" Width="300">
                                <StackPanel>
                                    <TextBlock Text="Provision a site" Style="{DynamicResource CardTitle}"/>
                                    <TextBlock Text="Create a site from a template and bulk-edit metadata." Style="{DynamicResource CardBody}"/>
                                    <TextBlock Text="New site · Template · CSV metadata" Style="{DynamicResource CardMeta}"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CardScheduled" Style="{DynamicResource Card}" Width="300">
                                <StackPanel>
                                    <TextBlock Text="Schedule a report" Style="{DynamicResource CardTitle}"/>
                                    <TextBlock Text="Drop governance reports on a cadence, no sign-in." Style="{DynamicResource CardBody}"/>
                                    <TextBlock Text="Daily / Weekly · App-only auth" Style="{DynamicResource CardMeta}"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                </StackPanel>

                <!-- CONNECT -->
                <Grid x:Name="ViewConnect" Margin="28,26" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Connect to SharePoint" Style="{DynamicResource Section}" Margin="0,0,0,12"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Site URL" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbUrl"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Client ID" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TbClientId"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Tenant" VerticalAlignment="Center"/>
                    <TextBox   Grid.Row="3" Grid.Column="1" x:Name="TbTenant"/>

                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                        <CheckBox x:Name="CbAdmin"  Content="Admin centre (tenant-wide)"/>
                        <CheckBox x:Name="CbDevice" Content="Device-code sign-in"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnConnect" Content="Connect"/>
                        <TextBlock Text="Saved defaults load automatically. Register an app first (docs/02)."
                                   Style="{DynamicResource Muted}" Margin="6,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- MIGRATE -->
                <DockPanel x:Name="ViewMigrate" Margin="28,26" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="Migrate a file share" Style="{DynamicResource Section}" Margin="0,0,0,12"/>
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Source folder" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TbSource"/>
                        <Button    Grid.Row="0" Grid.Column="2" x:Name="BtnBrowseSource" Content="Browse..." Style="{DynamicResource GhostButton}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Site URL" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbMigSite"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Library" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TbLibrary" Text="Documents"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Target sub-folder" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="TbTargetFolder"/>

                        <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <CheckBox x:Name="CbPreserve" Content="Preserve timestamps" IsChecked="True"/>
                            <CheckBox x:Name="CbOverwrite" Content="Overwrite existing"/>
                            <Button x:Name="BtnPreviewMig" Content="Preview (WhatIf)" Style="{DynamicResource WarnButton}"/>
                            <Button x:Name="BtnRunMig"     Content="Run migration"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <DataGrid x:Name="GridMig"/>
                        <TextBlock x:Name="EmptyMig" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                   Text="Pick a source folder and a site, then preview before you run."/>
                    </Grid>
                </DockPanel>

                <!-- COPY SITE (SharePoint → SharePoint) -->
                <DockPanel x:Name="ViewCopySite" Margin="28,26" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="Copy a SharePoint site" Style="{DynamicResource Section}" Margin="0,0,0,4"/>
                    <TextBlock DockPanel.Dock="Top" Style="{DynamicResource Muted}" Margin="0,0,0,18" TextWrapping="Wrap"
                               MaxWidth="680" HorizontalAlignment="Left"
                               Text="Copy a site's structure — lists, libraries, columns, content types, views — and optionally its items and files to another site in the same tenant. Preview the plan first; nothing is written until you run the copy."/>
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Step 1 · Source -->
                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource Accent}">
                                <TextBlock Text="1" Foreground="{DynamicResource AccentFg}" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Source" Foreground="{DynamicResource Fg}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="the site to copy from" Style="{DynamicResource Muted}" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Site URL" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbCopySource"/>

                        <!-- Step 2 · Destination -->
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,4">
                            <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource Accent}">
                                <TextBlock Text="2" Foreground="{DynamicResource AccentFg}" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Destination" Foreground="{DynamicResource Fg}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="an existing site in the same tenant" Style="{DynamicResource Muted}" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Site URL" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="TbCopyDest"/>

                        <!-- Step 3 · Options -->
                        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,4">
                            <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource Accent}">
                                <TextBlock Text="3" Foreground="{DynamicResource AccentFg}" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Options" Foreground="{DynamicResource Fg}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Lists (optional)" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="TbCopyLists" Width="320"/>
                            <TextBlock Text="comma-separated — blank copies every list and library" Style="{DynamicResource Muted}" Margin="12,0,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="On conflict" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                            <ComboBox x:Name="CbCopyConflict" Width="160" SelectedIndex="0">
                                <ComboBoxItem Content="IfNewer"/>
                                <ComboBoxItem Content="Skip"/>
                                <ComboBoxItem Content="KeepBoth"/>
                                <ComboBoxItem Content="Replace"/>
                            </ComboBox>
                            <CheckBox x:Name="CbCopyContent" Content="Include content (items + files)" Margin="18,6,0,6"/>
                            <CheckBox x:Name="CbCopyVersions" Content="Version history (experimental)" Margin="18,6,0,6"/>
                            <CheckBox x:Name="CbCopyPerms" Content="Copy permissions" Margin="18,6,0,6"/>
                        </StackPanel>

                        <!-- Step 4 · Run -->
                        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,4">
                            <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource Accent}">
                                <TextBlock Text="4" Foreground="{DynamicResource AccentFg}" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Preview, then copy" Foreground="{DynamicResource Fg}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="preview is a read-only pre-check — it writes nothing" Style="{DynamicResource Muted}" Margin="10,0,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="BtnPreviewCopy" Content="Preview plan (WhatIf)" Style="{DynamicResource WarnButton}"/>
                            <Button x:Name="BtnRunCopy"     Content="Copy site"/>
                            <Button x:Name="BtnValidateCopy" Content="Validate copy" Style="{DynamicResource GhostButton}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <DataGrid x:Name="GridCopy"/>
                        <TextBlock x:Name="EmptyCopy" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                   Text="Enter a source and destination site, then preview the plan before you copy."/>
                    </Grid>
                </DockPanel>

                <!-- PRE-CHECK -->
                <DockPanel x:Name="ViewPreCheck" Margin="28,26" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="Pre-check a source" Style="{DynamicResource Section}" Margin="0,0,0,4"/>
                    <TextBlock DockPanel.Dock="Top" Style="{DynamicResource Muted}" Margin="0,0,0,12" TextWrapping="Wrap"
                               Text="A local, read-only scan. Fix what shows up here and the migration runs clean."/>
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Source folder" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TbPreSource"/>
                        <Button    Grid.Row="0" Grid.Column="2" x:Name="BtnBrowsePreSource" Content="Browse..." Style="{DynamicResource GhostButton}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Target site (optional)" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbPreSite"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Library / max path" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="TbPreLibrary" Width="200" Text="Documents"/>
                            <TextBlock Text="Max path:" Style="{DynamicResource Muted}" Margin="12,0,8,0"/>
                            <TextBox x:Name="TbPreMaxPath" Width="80" Text="400"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <Button x:Name="BtnRunPrecheck" Content="Run pre-check"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <DataGrid x:Name="GridPrecheck"/>
                        <TextBlock x:Name="EmptyPrecheck" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                   Text="Choose a folder and run the check. Clean folders come back empty."/>
                    </Grid>
                </DockPanel>

                <!-- EXPLORE (SharePoint source assessment) -->
                <DockPanel x:Name="ViewExplore" Margin="28,26" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="Explore a source site" Style="{DynamicResource Section}" Margin="0,0,0,4"/>
                    <TextBlock DockPanel.Dock="Top" Style="{DynamicResource Muted}" Margin="0,0,0,12" TextWrapping="Wrap"
                               MaxWidth="700" HorizontalAlignment="Left"
                               Text="A read-only pre-migration assessment of a SharePoint source — checked-out files, large files, external sharing, orphaned users, 2013 workflows. Run the full assessment or one report. Nothing is written."/>
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Report" VerticalAlignment="Center"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="CbExplore" SelectedIndex="0" HorizontalAlignment="Left" Width="320">
                            <ComboBoxItem Content="Full assessment"/>
                            <ComboBoxItem Content="Checked-out files"/>
                            <ComboBoxItem Content="Large files"/>
                            <ComboBoxItem Content="Version history"/>
                            <ComboBoxItem Content="Content insights (by file type)"/>
                            <ComboBoxItem Content="Workflows (2013)"/>
                            <ComboBoxItem Content="Inactive sites (admin, tenant-wide)"/>
                        </ComboBox>
                        <Button    Grid.Row="0" Grid.Column="2" x:Name="BtnRunExplore" Content="Run"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Site URL" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbExploreSite"/>

                        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <TextBlock Text="Large file MB:" Style="{DynamicResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="TbExploreMB" Width="70" Text="100"/>
                            <CheckBox x:Name="CbExploreVersions" Content="Include version history (slower)" Margin="18,6,0,6"/>
                            <Button x:Name="BtnExploreCsv"  Content="Export CSV"  Style="{DynamicResource GoodButton}"/>
                            <Button x:Name="BtnExploreHtml" Content="Export HTML" Style="{DynamicResource GoodButton}"/>
                        </StackPanel>
                    </Grid>

                    <Border DockPanel.Dock="Top" Margin="0,12,0,0" Padding="12,8" CornerRadius="6"
                            Background="{DynamicResource BgElev}" BorderBrush="{DynamicResource Border}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Remediate:" Style="{DynamicResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CbRemediate" Width="260" SelectedIndex="0">
                                <ComboBoxItem Content="Check in all checked-out files"/>
                                <ComboBoxItem Content="Remove orphaned users"/>
                            </ComboBox>
                            <Button x:Name="BtnRemediatePreview" Content="Preview (WhatIf)" Style="{DynamicResource WarnButton}"/>
                            <Button x:Name="BtnRemediateApply" Content="Apply"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,14,0,0">
                        <DataGrid x:Name="GridExplore"/>
                        <TextBlock x:Name="EmptyExplore" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                   Text="Pick a report and a source site, then run. A clean full assessment comes back empty."/>
                    </Grid>
                </DockPanel>

                <!-- PROVISION -->
                <DockPanel x:Name="ViewProvision" Margin="28,26" Visibility="Collapsed">
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="Create a site" Style="{DynamicResource Section}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Title" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbSiteTitle"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Type" VerticalAlignment="Center"/>
                        <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="CbSiteType" SelectedIndex="0">
                            <ComboBoxItem Content="TeamSite"/>
                            <ComboBoxItem Content="CommunicationSite"/>
                        </ComboBox>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Alias / URL" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="TbSiteAlias"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Template (optional)" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="TbTemplatePath"/>
                        <Button    Grid.Row="4" Grid.Column="2" x:Name="BtnBrowseTemplate" Content="Browse..." Style="{DynamicResource GhostButton}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Libraries (optional)" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <TextBox x:Name="TbLibraries" Width="320"/>
                            <TextBlock Text="comma-separated" Style="{DynamicResource Muted}" Margin="10,0,0,0"/>
                            <Button x:Name="BtnCreateSite" Content="Create site" Margin="14,8,8,8"/>
                        </StackPanel>

                        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Text="Bulk metadata (CSV)" Style="{DynamicResource Section}" Margin="0,18,0,0"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Site / List" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <TextBox x:Name="TbBulkSite" Width="300"/>
                            <TextBlock Text="List:" Style="{DynamicResource Muted}" Margin="12,0,8,0"/>
                            <TextBox x:Name="TbBulkList" Width="150" Text="Documents"/>
                            <TextBox x:Name="TbBulkCsv" Width="220" Margin="12,5,0,5"/>
                            <Button x:Name="BtnBrowseCsv" Content="CSV..." Style="{DynamicResource GhostButton}"/>
                            <Button x:Name="BtnPreviewBulk" Content="Preview" Style="{DynamicResource WarnButton}"/>
                            <Button x:Name="BtnRunBulk" Content="Apply"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <DataGrid x:Name="GridProvision"/>
                        <TextBlock x:Name="EmptyProvision" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                   Text="Create a site or apply a CSV — results land here."/>
                    </Grid>
                </DockPanel>

                <!-- REPORTS -->
                <DockPanel x:Name="ViewReports" Margin="28,26" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="Report on access" Style="{DynamicResource Section}" Margin="0,0,0,12"/>
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Report" VerticalAlignment="Center"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="CbReport" SelectedIndex="0">
                            <ComboBoxItem Content="Sharing (external users + links)"/>
                            <ComboBoxItem Content="Permissions (who has access)"/>
                            <ComboBoxItem Content="Site inventory (admin, tenant-wide)"/>
                            <ComboBoxItem Content="Permissions matrix (who can touch what)"/>
                            <ComboBoxItem Content="Orphaned users (stale access)"/>
                        </ComboBox>
                        <Button Grid.Row="0" Grid.Column="2" x:Name="BtnRunReport" Content="Run report"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Site URL" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbReportSite"/>

                        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <CheckBox x:Name="CbInclLists" Content="Include list permissions / sharing links"/>
                            <Button x:Name="BtnExportCsv"  Content="Export CSV"  Style="{DynamicResource GoodButton}"/>
                            <Button x:Name="BtnExportHtml" Content="Export HTML" Style="{DynamicResource GoodButton}"/>
                        </StackPanel>
                    </Grid>

                    <Border DockPanel.Dock="Top" Margin="0,12,0,0" Padding="12,8" CornerRadius="6"
                            Background="{DynamicResource BgElev}" BorderBrush="{DynamicResource Border}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Site lifecycle:" Style="{DynamicResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CbLifecycle" Width="170" SelectedIndex="0">
                                <ComboBoxItem Content="ReadOnly (archive)"/>
                                <ComboBoxItem Content="NoAccess (lock)"/>
                                <ComboBoxItem Content="Unlock"/>
                            </ComboBox>
                            <Button x:Name="BtnLifecyclePreview" Content="Preview (WhatIf)" Style="{DynamicResource WarnButton}"/>
                            <Button x:Name="BtnLifecycleApply" Content="Apply"/>
                            <TextBlock Text="uses the Site URL above · needs admin" Style="{DynamicResource Muted}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,14,0,0">
                        <DataGrid x:Name="GridReport"/>
                        <TextBlock x:Name="EmptyReport" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                   Text="Run a report to see who can reach a site."/>
                    </Grid>
                </DockPanel>

                <!-- SCHEDULED -->
                <DockPanel x:Name="ViewScheduled" Margin="28,26" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="Schedule a report" Style="{DynamicResource Section}" Margin="0,0,0,4"/>
                    <TextBlock DockPanel.Dock="Top" Style="{DynamicResource Muted}" Margin="0,0,0,12" TextWrapping="Wrap"
                               Text="Build the command, then create a Windows task that runs it unattended. App-only auth (a certificate thumbprint) keeps it sign-in free."/>
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Site URL" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TbSchedSite"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Reports" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                            <CheckBox x:Name="CbSchedSharing" Content="Sharing" IsChecked="True"/>
                            <CheckBox x:Name="CbSchedPerms"   Content="Permissions" IsChecked="True"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Output folder" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TbSchedOut" Text="C:\OpenGateSP\reports"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="When" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                            <ComboBox x:Name="CbSchedFreq" Width="140" SelectedIndex="0">
                                <ComboBoxItem Content="Daily"/>
                                <ComboBoxItem Content="Weekly"/>
                            </ComboBox>
                            <TextBlock Text="at" Style="{DynamicResource Muted}" Margin="12,0,8,0"/>
                            <TextBox x:Name="TbSchedAt" Width="90" Text="07:00"/>
                            <TextBlock Text="Thumbprint:" Style="{DynamicResource Muted}" Margin="16,0,8,0"/>
                            <TextBox x:Name="TbSchedThumb" Width="240"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="BtnPreviewSchedule" Content="Build command" Style="{DynamicResource GhostButton}"/>
                            <Button x:Name="BtnCreateSchedule"  Content="Create task"/>
                        </StackPanel>
                    </Grid>

                    <TextBox x:Name="TbSchedCommand" DockPanel.Dock="Top" Margin="0,14,0,0" IsReadOnly="True"
                             TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" MinHeight="80"
                             VerticalScrollBarVisibility="Auto"/>
                    <Grid/>
                </DockPanel>

                <!-- COLLABORATION (Teams / M365 Groups / Planner) -->
                <DockPanel x:Name="ViewCollab" Margin="28,26" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="Clone Teams, Groups &amp; Planner" Style="{DynamicResource Section}" Margin="0,0,0,4"/>
                    <TextBlock DockPanel.Dock="Top" Style="{DynamicResource Muted}" Margin="0,0,0,14" TextWrapping="Wrap"
                               MaxWidth="700" HorizontalAlignment="Left"
                               Text="Model a new Microsoft 365 Group, Team, or Planner plan on an existing one. Preview is a dry-run; Create writes. Needs Microsoft Graph scopes on the app registration."/>
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Microsoft 365 Group" Style="{DynamicResource Section}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Source (id / name)" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbGroupSource"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="New display name" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TbGroupName"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Mail nickname" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="TbGroupAlias" Width="220"/>
                            <Button x:Name="BtnPreviewGroup" Content="Preview" Style="{DynamicResource WarnButton}"/>
                            <Button x:Name="BtnCreateGroup" Content="Create"/>
                        </StackPanel>

                        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="Microsoft Teams team" Style="{DynamicResource Section}" Margin="0,16,0,6"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Source (id / name)" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="5" Grid.Column="1" x:Name="TbTeamSource"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="New display name" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="6" Grid.Column="1" x:Name="TbTeamName"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Mail nickname" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="TbTeamAlias" Width="220"/>
                            <Button x:Name="BtnPreviewTeam" Content="Preview" Style="{DynamicResource WarnButton}"/>
                            <Button x:Name="BtnCreateTeam" Content="Create"/>
                        </StackPanel>

                        <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Text="Planner plan" Style="{DynamicResource Section}" Margin="0,16,0,6"/>
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Source plan id" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="9" Grid.Column="1" x:Name="TbPlanSource"/>
                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Dest group id" VerticalAlignment="Center"/>
                        <TextBox   Grid.Row="10" Grid.Column="1" x:Name="TbPlanGroup"/>
                        <TextBlock Grid.Row="11" Grid.Column="0" Text="New plan title" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="TbPlanTitle" Width="220"/>
                            <Button x:Name="BtnPreviewPlan" Content="Preview" Style="{DynamicResource WarnButton}"/>
                            <Button x:Name="BtnCreatePlan" Content="Create"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <DataGrid x:Name="GridCollab"/>
                        <TextBlock x:Name="EmptyCollab" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                   Text="Pick a source and fill in the new names, then preview before you create."/>
                    </Grid>
                </DockPanel>

                <!-- COPY — landing chooser ("What would you like to copy?") -->
                <DockPanel x:Name="ViewCopyLanding" Margin="28,26" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="What would you like to copy?" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Fg}"/>
                    <TextBlock DockPanel.Dock="Top" Style="{DynamicResource Muted}" Margin="0,8,0,16" TextWrapping="Wrap" MaxWidth="700" HorizontalAlignment="Left"
                               Text="Pick what to copy. Every option previews before it writes — nothing changes until you run it."/>
                    <TabControl DockPanel.Dock="Top" x:Name="TabCopyKind">
                        <TabItem Header="SharePoint">
                            <WrapPanel Margin="0,18,0,0">
                                <Button x:Name="CardCopyStructure" Style="{DynamicResource Card}" Width="320">
                                    <StackPanel>
                                        <TextBlock Text="Structure &amp; content" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="Lists &amp; libraries, columns, content types and views — plus the items and files inside them." Style="{DynamicResource CardBody}"/>
                                        <TextBlock Text="Schema · Items · Files · Optional versions" Style="{DynamicResource CardMeta}"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="CardCopyStructureOnly" Style="{DynamicResource Card}" Width="320">
                                    <StackPanel>
                                        <TextBlock Text="Structure only" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="The site's shape — lists, libraries, columns, content types, views — with no items or files." Style="{DynamicResource CardBody}"/>
                                        <TextBlock Text="Schema · Groups · Permission levels" Style="{DynamicResource CardMeta}"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="CardCopyContent" Style="{DynamicResource Card}" Width="320">
                                    <StackPanel>
                                        <TextBlock Text="Content only" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="Items and files into lists and libraries that already exist at the destination." Style="{DynamicResource CardBody}"/>
                                        <TextBlock Text="Items · Files · Honours conflict mode" Style="{DynamicResource CardMeta}"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="CardCopyList" Style="{DynamicResource Card}" Width="320">
                                    <StackPanel>
                                        <TextBlock Text="A single list or library" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="One list or library — its schema and views, optionally its items and files." Style="{DynamicResource CardBody}"/>
                                        <TextBlock Text="One list · Schema · Optional content" Style="{DynamicResource CardMeta}"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </TabItem>
                        <TabItem Header="Collaboration">
                            <WrapPanel Margin="0,18,0,0">
                                <Button x:Name="CardCopyTeam" Style="{DynamicResource Card}" Width="320">
                                    <StackPanel>
                                        <TextBlock Text="A Team" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="Channels and the owner/member roster. Messages and files aren't copied." Style="{DynamicResource CardBody}"/>
                                        <TextBlock Text="Channels · Members · Needs Graph" Style="{DynamicResource CardMeta}"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="CardCopyGroup" Style="{DynamicResource Card}" Width="320">
                                    <StackPanel>
                                        <TextBlock Text="A Microsoft 365 Group" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="A new group modelled on an existing one — description, owners and members." Style="{DynamicResource CardBody}"/>
                                        <TextBlock Text="Group · Owners · Members" Style="{DynamicResource CardMeta}"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="CardCopyPlanner" Style="{DynamicResource Card}" Width="320">
                                    <StackPanel>
                                        <TextBlock Text="A Planner plan" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="Recreate a plan's buckets and tasks on a destination group." Style="{DynamicResource CardBody}"/>
                                        <TextBlock Text="Plan · Buckets · Tasks" Style="{DynamicResource CardMeta}"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </TabItem>
                        <TabItem Header="Import external">
                            <WrapPanel Margin="0,18,0,0">
                                <Button x:Name="CardImportFileShare" Style="{DynamicResource Card}" Width="320">
                                    <StackPanel>
                                        <TextBlock Text="A file share" Style="{DynamicResource CardTitle}"/>
                                        <TextBlock Text="A local or network folder into a SharePoint library, timestamps intact. Pre-checked for blockers first." Style="{DynamicResource CardBody}"/>
                                        <TextBlock Text="Files · Folders · Timestamps" Style="{DynamicResource CardMeta}"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </TabItem>
                    </TabControl>
                    <TextBlock DockPanel.Dock="Top" Text="Recent copies" Style="{DynamicResource Section}" Margin="0,22,0,8"/>
                    <Grid>
                        <DataGrid x:Name="GridRecent"/>
                        <TextBlock x:Name="EmptyRecent" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                   Text="Your copies will show up here. Pick a card above to start."/>
                    </Grid>
                </DockPanel>

                <!-- COPY — guided wizard -->
                <Grid x:Name="ViewCopyWizard" Margin="28,20" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Step rail -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
                        <TextBlock x:Name="WizTypeChip" Text="Structure &amp; content" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentFg}" Background="{DynamicResource Accent}" Padding="10,4" Margin="0,0,14,0"/>
                        <TextBlock x:Name="WizStep1" Text="1  Source"        FontWeight="Bold" Foreground="{DynamicResource Accent}" VerticalAlignment="Center"/>
                        <TextBlock Text="  ›  " Style="{DynamicResource Muted}"/>
                        <TextBlock x:Name="WizStep2" Text="2  Destination"   Foreground="{DynamicResource FgMute}" VerticalAlignment="Center"/>
                        <TextBlock Text="  ›  " Style="{DynamicResource Muted}"/>
                        <TextBlock x:Name="WizStep3" Text="3  Scope"         Foreground="{DynamicResource FgMute}" VerticalAlignment="Center"/>
                        <TextBlock Text="  ›  " Style="{DynamicResource Muted}"/>
                        <TextBlock x:Name="WizStep4" Text="4  Options"       Foreground="{DynamicResource FgMute}" VerticalAlignment="Center"/>
                        <TextBlock Text="  ›  " Style="{DynamicResource Muted}"/>
                        <TextBlock x:Name="WizStep5" Text="5  Preview &amp; run" Foreground="{DynamicResource FgMute}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Step panels -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <!-- 1 Source -->
                            <StackPanel x:Name="PanelWizSource">
                                <TextBlock Text="Select source" Style="{DynamicResource Section}" FontSize="18" Foreground="{DynamicResource Fg}"/>
                                <TextBlock Style="{DynamicResource Muted}" Margin="0,4,0,14" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left"
                                           Text="The site you're copying from, in the tenant you're connected to. Connect from the bottom-left if the dot isn't green."/>
                                <TextBlock Text="Source site URL" VerticalAlignment="Center"/>
                                <TextBox x:Name="TbWizSource" Width="560" HorizontalAlignment="Left"/>
                                <TextBlock Style="{DynamicResource Muted}" Margin="0,8,0,0" TextWrapping="Wrap" MaxWidth="560" HorizontalAlignment="Left"
                                           Text="Same-tenant copy. For tenant-to-tenant, use the PowerShell or MCP surface (app-only certificate per tenant)."/>
                            </StackPanel>

                            <!-- 2 Destination -->
                            <StackPanel x:Name="PanelWizDest" Visibility="Collapsed">
                                <TextBlock Text="Select destination" Style="{DynamicResource Section}" FontSize="18" Foreground="{DynamicResource Fg}"/>
                                <TextBlock Style="{DynamicResource Muted}" Margin="0,4,0,14" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left"
                                           Text="An existing site to copy into. It must be different from the source. Need a new one? Create it under Provisioning first."/>
                                <TextBlock Text="Destination site URL" VerticalAlignment="Center"/>
                                <TextBox x:Name="TbWizDest" Width="560" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <!-- 3 Scope -->
                            <DockPanel x:Name="PanelWizScope" Visibility="Collapsed">
                                <TextBlock DockPanel.Dock="Top" Text="Choose what to copy" Style="{DynamicResource Section}" FontSize="18" Foreground="{DynamicResource Fg}"/>
                                <TextBlock DockPanel.Dock="Top" Style="{DynamicResource Muted}" Margin="0,4,0,12" TextWrapping="Wrap" MaxWidth="700" HorizontalAlignment="Left"
                                           Text="Load the lists on both sides to see what's there. Leave the box blank to copy everything, or list the names to copy just those."/>
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Lists (optional)" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="TbWizLists" Width="360" ToolTip="Blank copies every list and library. Comma-separate display names to copy only those."/>
                                    <Button x:Name="BtnWizLoadLists" Content="Load lists" Style="{DynamicResource GhostButton}"/>
                                    <TextBlock Text="blank = copy every list and library" Style="{DynamicResource Muted}" Margin="12,0,0,0"/>
                                </StackPanel>
                                <Grid>
                                    <DataGrid x:Name="GridWizScope"/>
                                    <TextBlock x:Name="EmptyWizScope" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                               Text="Load lists to compare source and destination before you copy."/>
                                </Grid>
                            </DockPanel>

                            <!-- 4 Options -->
                            <StackPanel x:Name="PanelWizOptions" Visibility="Collapsed">
                                <TextBlock Text="Copy options" Style="{DynamicResource Section}" FontSize="18" Foreground="{DynamicResource Fg}"/>
                                <TextBlock Style="{DynamicResource Muted}" Margin="0,4,0,14" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left"
                                           Text="How to handle what's already there, and what to bring along."/>
                                <TextBlock Text="If items already exist at the destination" VerticalAlignment="Center"/>
                                <ComboBox x:Name="CbWizConflict" Width="260" HorizontalAlignment="Left" SelectedIndex="0"
                                          ToolTip="What to do when an item already exists at the destination.">
                                    <ComboBoxItem Content="Copy if newer"/>
                                    <ComboBoxItem Content="Don't copy (skip)"/>
                                    <ComboBoxItem Content="Keep both"/>
                                    <ComboBoxItem Content="Copy and replace"/>
                                </ComboBox>
                                <TextBlock Text="Include" Style="{DynamicResource Section}" Foreground="{DynamicResource Fg}" Margin="0,16,0,4"/>
                                <CheckBox x:Name="CbWizContent" Content="Items and files (content)" IsChecked="True"/>
                                <CheckBox x:Name="CbWizVersions" Content="Version history (experimental — author/date not preserved per version)"/>
                                <CheckBox x:Name="CbWizPerms" Content="Custom permissions"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="Only items modified since" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="TbWizSince" Width="160"/>
                                    <TextBlock Text="optional — e.g. 2026-01-01 (incremental)" Style="{DynamicResource Muted}" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 5 Preview &amp; run -->
                            <DockPanel x:Name="PanelWizRun" Visibility="Collapsed">
                                <TextBlock DockPanel.Dock="Top" Text="Preview, then run" Style="{DynamicResource Section}" FontSize="18" Foreground="{DynamicResource Fg}"/>
                                <Border DockPanel.Dock="Top" Margin="0,8,0,12" Padding="14,12" CornerRadius="8"
                                        Background="{DynamicResource BgElev}" BorderBrush="{DynamicResource Border}" BorderThickness="1">
                                    <TextBlock x:Name="WizSummary" TextWrapping="Wrap" Foreground="{DynamicResource Fg}"
                                               Text="Review the plan, then run. Preview writes nothing."/>
                                </Border>
                                <TextBlock DockPanel.Dock="Top" Style="{DynamicResource Muted}" Margin="0,0,0,8"
                                           Text="Run is unlocked once you've previewed the current settings."/>
                                <Grid>
                                    <DataGrid x:Name="GridWizResult"/>
                                    <TextBlock x:Name="EmptyWizResult" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                               Text="Preview the plan to see exactly what will be created, skipped or overwritten."/>
                                </Grid>
                            </DockPanel>
                        </Grid>
                    </ScrollViewer>

                    <!-- Footer -->
                    <DockPanel Grid.Row="2" Margin="0,14,0,0">
                        <Button x:Name="BtnWizBack" DockPanel.Dock="Left" Content="‹ Back" Style="{DynamicResource GhostButton}"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="BtnWizPreview" Content="Preview plan" Style="{DynamicResource WarnButton}" Visibility="Collapsed"/>
                            <Button x:Name="BtnWizRun" Content="Run copy" Visibility="Collapsed" IsEnabled="False"/>
                            <Button x:Name="BtnWizNext" Content="Next ›"/>
                        </StackPanel>
                        <TextBlock x:Name="WizStepLabel" Text="Step 1 of 5" Style="{DynamicResource Muted}" HorizontalAlignment="Center"/>
                    </DockPanel>
                </Grid>

                <!-- TASKS — recent run history -->
                <DockPanel x:Name="ViewTasks" Margin="28,26" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="Tasks" Style="{DynamicResource Section}" FontSize="18" Foreground="{DynamicResource Fg}" Margin="0,0,0,4"/>
                    <TextBlock DockPanel.Dock="Top" Style="{DynamicResource Muted}" Margin="0,0,0,12" TextWrapping="Wrap"
                               Text="What's run this session. Full transcripts are written to the ./logs folder next to the app."/>
                    <Grid>
                        <DataGrid x:Name="GridTasks"/>
                        <TextBlock x:Name="EmptyTasks" IsHitTestVisible="False" Style="{DynamicResource EmptyState}"
                                   Text="Operations you run will be listed here with their result."/>
                    </Grid>
                </DockPanel>

                <!-- SETTINGS (opened from the app-bar cog) -->
                <DockPanel x:Name="ViewSettings" Margin="28,26" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="Settings" Style="{DynamicResource Section}" FontSize="18" Foreground="{DynamicResource Fg}" Margin="0,0,0,18"/>
                    <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                        <TextBlock Text="Appearance" Style="{DynamicResource Section}" Foreground="{DynamicResource Fg}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Theme" VerticalAlignment="Center" Width="120"/>
                            <ComboBox x:Name="CbTheme" Width="200" ToolTip="Theme"/>
                        </StackPanel>
                        <Border Height="1" Background="{DynamicResource Border}" Margin="0,18"/>

                        <TextBlock Text="Connection" Style="{DynamicResource Section}" Foreground="{DynamicResource Fg}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="SetConnSummary" Text="Not connected." Style="{DynamicResource Muted}" Margin="0,0,0,10"/>
                        <Button x:Name="BtnManageConnection" Content="Manage connection" Style="{DynamicResource GhostButton}" HorizontalAlignment="Left"/>
                        <Border Height="1" Background="{DynamicResource Border}" Margin="0,18"/>

                        <TextBlock Text="Logs &amp; data" Style="{DynamicResource Section}" Foreground="{DynamicResource Fg}" Margin="0,0,0,6"/>
                        <TextBlock Text="Run transcripts and report exports are written next to the app." Style="{DynamicResource Muted}" Margin="0,0,0,10"/>
                        <Button x:Name="BtnOpenLogs" Content="Open logs folder" Style="{DynamicResource GhostButton}" HorizontalAlignment="Left"/>
                        <Border Height="1" Background="{DynamicResource Border}" Margin="0,18"/>

                        <TextBlock Text="About" Style="{DynamicResource Section}" Foreground="{DynamicResource Fg}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="SetAbout" Text="OpenGateSP" Foreground="{DynamicResource Fg}" Margin="0,0,0,2"/>
                        <TextBlock Text="The free, open-source ShareGate alternative · MIT" Style="{DynamicResource Muted}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnCheckUpdates" Content="Check for updates"/>
                            <Button x:Name="BtnDocs" Content="Documentation" Style="{DynamicResource GhostButton}"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>

                </Grid>
              </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>

    <!-- Toast overlay (top-right, above content) -->
    <StackPanel x:Name="ToastHost" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,66,18,0" Panel.ZIndex="100"/>

    <!-- Keyboard shortcuts overlay (toggle with ?) -->
    <Grid x:Name="ShortcutsOverlay" Visibility="Collapsed" Panel.ZIndex="200" Background="#99000000">
        <Border Background="{DynamicResource BgElev}" BorderBrush="{DynamicResource BorderStrong}" BorderThickness="1" CornerRadius="12"
                HorizontalAlignment="Center" VerticalAlignment="Center" Padding="28" MaxWidth="440">
            <StackPanel>
                <TextBlock Text="Keyboard shortcuts" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Fg}" Margin="0,0,0,16"/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="?" FontFamily="Consolas" Foreground="{DynamicResource Accent}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Show or hide this help" Foreground="{DynamicResource Fg}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Esc" FontFamily="Consolas" Foreground="{DynamicResource Accent}" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Close this help or a dialog" Foreground="{DynamicResource Fg}" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl + ," FontFamily="Consolas" Foreground="{DynamicResource Accent}" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Open Settings" Foreground="{DynamicResource Fg}" Margin="0,8,0,0"/>
                </Grid>
                <TextBlock Text="Press Esc or ? to close." Style="{DynamicResource Muted}" Margin="0,16,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
    </Grid>
</Window>
