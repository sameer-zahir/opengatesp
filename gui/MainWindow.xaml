<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenGateSP" Height="740" Width="1120"
        WindowStartupLocation="CenterScreen" Background="#1b1d2b">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#c0caf5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,8,4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#24283b"/>
            <Setter Property="Foreground" Value="#c0caf5"/>
            <Setter Property="BorderBrush" Value="#3b4261"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="CaretBrush" Value="#c0caf5"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#24283b"/>
            <Setter Property="Foreground" Value="#1b1d2b"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#c0caf5"/>
            <Setter Property="Margin" Value="0,6,16,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#7aa2f7"/>
            <Setter Property="Foreground" Value="#1b1d2b"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,8,8,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1f2335"/>
            <Setter Property="Foreground" Value="#c0caf5"/>
            <Setter Property="RowBackground" Value="#1f2335"/>
            <Setter Property="AlternatingRowBackground" Value="#24283b"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3b4261"/>
            <Setter Property="BorderBrush" Value="#3b4261"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,6"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#16161e" Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="OpenGateSP" FontSize="18" FontWeight="Bold" Foreground="#7aa2f7"/>
                <TextBlock Text="  &#8226;  " Foreground="#565f89"/>
                <TextBlock x:Name="ConnStatus" Text="Not connected" Foreground="#e0af68"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#16161e" Padding="16,8">
            <TextBlock x:Name="StatusText" Text="Ready." Foreground="#9aa5ce"/>
        </Border>

        <TabControl x:Name="Tabs" Background="#1b1d2b" BorderBrush="#3b4261" Margin="8">

            <!-- CONNECT -->
            <TabItem Header="Connect">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Site URL"/>
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TbUrl"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Client ID"/>
                    <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbClientId"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tenant"/>
                    <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TbTenant"/>

                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                        <CheckBox x:Name="CbAdmin"  Content="Admin centre (tenant-wide)"/>
                        <CheckBox x:Name="CbDevice" Content="Device-code sign-in"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnConnect" Content="Connect"/>
                        <TextBlock Text="Saved defaults load automatically. Register an app first (docs/02)."
                                   Foreground="#565f89" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- REPORTS -->
            <TabItem Header="Reports">
                <DockPanel Margin="20">
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Report"/>
                        <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="CbReport" SelectedIndex="0">
                            <ComboBoxItem Content="Sharing (external users + links)"/>
                            <ComboBoxItem Content="Permissions (who has access)"/>
                            <ComboBoxItem Content="Site inventory (admin, tenant-wide)"/>
                        </ComboBox>
                        <Button Grid.Row="0" Grid.Column="2" x:Name="BtnRunReport" Content="Run report"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Site URL"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbReportSite"/>

                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <CheckBox x:Name="CbInclLists" Content="Include list permissions / sharing links"/>
                            <Button x:Name="BtnExportCsv"  Content="Export CSV"  Background="#9ece6a"/>
                            <Button x:Name="BtnExportHtml" Content="Export HTML" Background="#9ece6a"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="GridReport" Margin="0,12,0,0"/>
                </DockPanel>
            </TabItem>

            <!-- MIGRATE -->
            <TabItem Header="Migrate">
                <DockPanel Margin="20">
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Source folder"/>
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TbSource"/>
                        <Button    Grid.Row="0" Grid.Column="2" x:Name="BtnBrowseSource" Content="Browse..." Background="#bb9af7"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Site URL"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbMigSite"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Library"/>
                        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TbLibrary" Text="Documents"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Target sub-folder"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="TbTargetFolder"/>

                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                            <CheckBox x:Name="CbPreserve" Content="Preserve timestamps" IsChecked="True"/>
                            <CheckBox x:Name="CbOverwrite" Content="Overwrite existing"/>
                            <Button x:Name="BtnPreviewMig" Content="Preview (WhatIf)" Background="#e0af68"/>
                            <Button x:Name="BtnRunMig"     Content="Run migration"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="GridMig" Margin="0,12,0,0"/>
                </DockPanel>
            </TabItem>

            <!-- PROVISION -->
            <TabItem Header="Provision">
                <DockPanel Margin="20">
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Create a site" FontWeight="Bold" Foreground="#7aa2f7"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Title"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TbSiteTitle"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Type"/>
                        <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="CbSiteType" SelectedIndex="0">
                            <ComboBoxItem Content="TeamSite"/>
                            <ComboBoxItem Content="CommunicationSite"/>
                        </ComboBox>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Alias / URL"/>
                        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="TbSiteAlias"/>
                        <Button    Grid.Row="3" Grid.Column="2" x:Name="BtnCreateSite" Content="Create site"/>

                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Bulk metadata (CSV)" FontWeight="Bold" Foreground="#7aa2f7" Margin="0,16,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Site / List"/>
                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="TbBulkSite" Width="320"/>
                            <TextBlock Text="  List:  "/>
                            <TextBox x:Name="TbBulkList" Width="160" Text="Documents"/>
                        </StackPanel>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="CSV path"/>
                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="TbBulkCsv" Width="320"/>
                            <Button x:Name="BtnBrowseCsv" Content="Browse..." Background="#bb9af7"/>
                            <Button x:Name="BtnPreviewBulk" Content="Preview (WhatIf)" Background="#e0af68"/>
                            <Button x:Name="BtnRunBulk" Content="Apply"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="GridProvision" Margin="0,12,0,0"/>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
